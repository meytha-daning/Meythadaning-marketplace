rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products collection: readable and writable by anyone (avoids permission errors)
    match /products/{productId} {
      allow read, write: if true;
    }

    // Transactions collection: readable and writable by anyone
    match /transactions/{transactionId} {
      allow read, write: if true;
    }

    // Users collection: readable and writable by anyone
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
